<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape Mode Dashboard – 3-column grid layout -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:paddingTop="12dp" android:paddingBottom="12dp">

        <!-- Compact header row -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⬡  SENSORPRO  DASHBOARD"
                android:textColor="@color/accent_cyan"
                android:textSize="13sp" android:fontFamily="monospace"/>
            <TextView android:id="@+id/tvStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="● LIVE" android:textColor="@color/accent_green"
                android:textSize="11sp" android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Status mini-bar -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <TextView android:id="@+id/tvActivity"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🧍 Detecting…" android:textColor="@color/text_primary"
                android:textSize="12sp"/>
            <TextView android:id="@+id/tvSteps"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="👟 —" android:textColor="@color/accent_green"
                android:textSize="12sp" android:gravity="center"/>
            <TextView android:id="@+id/tvShake"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="" android:textColor="@color/accent_cyan"
                android:textSize="12sp" android:gravity="end"/>
        </LinearLayout>

        <!-- 3-column sensor cards -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Accelerometer -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAccel"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="16dp"
                app:strokeColor="@color/divider" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📡" android:textSize="16sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="8dp"
                            android:text="Accelerometer" android:textColor="@color/text_primary"
                            android:textSize="12sp" android:textStyle="bold"/>
                        <View android:id="@+id/dotAccel" android:layout_width="7dp"
                            android:layout_height="7dp" android:background="@drawable/dot_cyan"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvAccelX" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="X 0.000"
                        android:textColor="@color/accent_cyan" android:textSize="11sp"
                        android:fontFamily="monospace"/>
                    <TextView android:id="@+id/tvAccelY" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Y 0.000"
                        android:textColor="@color/accent_green" android:textSize="11sp"
                        android:fontFamily="monospace"/>
                    <TextView android:id="@+id/tvAccelZ" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Z 0.000"
                        android:textColor="@color/accent_amber" android:textSize="11sp"
                        android:fontFamily="monospace"/>
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="6dp">
                        <TextView android:id="@+id/tvAccelMin" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textColor="@color/text_secondary"
                            android:textSize="10sp" android:fontFamily="monospace"/>
                        <TextView android:id="@+id/tvAccelAvg" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textColor="@color/accent_cyan"
                            android:textSize="10sp" android:fontFamily="monospace" android:gravity="center"/>
                        <TextView android:id="@+id/tvAccelMax" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textColor="@color/accent_red"
                            android:textSize="10sp" android:fontFamily="monospace" android:gravity="end"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Light -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLight"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="16dp"
                app:strokeColor="@color/divider" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="☀️" android:textSize="16sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="8dp"
                            android:text="Light" android:textColor="@color/text_primary"
                            android:textSize="12sp" android:textStyle="bold"/>
                        <View android:id="@+id/dotLight" android:layout_width="7dp"
                            android:layout_height="7dp" android:background="@drawable/dot_amber"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvLightVal" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="— lx"
                        android:textColor="@color/accent_amber" android:textSize="22sp"
                        android:textStyle="bold" android:fontFamily="monospace"
                        android:layout_marginBottom="6dp"/>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressLight"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        app:trackThickness="5dp" app:trackCornerRadius="3dp"
                        app:indicatorColor="@color/accent_amber" app:trackColor="@color/divider"
                        android:progress="0" android:layout_marginBottom="6dp"/>
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:id="@+id/tvLightMin" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textColor="@color/text_secondary"
                            android:textSize="10sp" android:fontFamily="monospace"/>
                        <TextView android:id="@+id/tvLightAvg" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textColor="@color/accent_amber"
                            android:textSize="10sp" android:fontFamily="monospace" android:gravity="center"/>
                        <TextView android:id="@+id/tvLightMax" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textColor="@color/accent_red"
                            android:textSize="10sp" android:fontFamily="monospace" android:gravity="end"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Proximity -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProx"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="16dp"
                app:strokeColor="@color/divider" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📶" android:textSize="16sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="8dp"
                            android:text="Proximity" android:textColor="@color/text_primary"
                            android:textSize="12sp" android:textStyle="bold"/>
                        <View android:id="@+id/dotProx" android:layout_width="7dp"
                            android:layout_height="7dp" android:background="@drawable/dot_green"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvProxVal" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textColor="@color/accent_green" android:textSize="22sp"
                        android:textStyle="bold" android:fontFamily="monospace"
                        android:layout_marginBottom="6dp"/>
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:id="@+id/tvProxMin" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textColor="@color/text_secondary"
                            android:textSize="10sp" android:fontFamily="monospace"/>
                        <TextView android:id="@+id/tvProxMax" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textColor="@color/accent_red"
                            android:textSize="10sp" android:fontFamily="monospace" android:gravity="end"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
