<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Dots + buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="40dp">

        <!-- Dot indicators -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <View android:id="@+id/dot1" android:layout_width="10dp" android:layout_height="10dp"
                android:layout_marginEnd="8dp" android:background="@drawable/dot_cyan"/>
            <View android:id="@+id/dot2" android:layout_width="10dp" android:layout_height="10dp"
                android:layout_marginEnd="8dp" android:background="@drawable/dot_cyan" android:alpha="0.35"/>
            <View android:id="@+id/dot3" android:layout_width="10dp" android:layout_height="10dp"
                android:background="@drawable/dot_cyan" android:alpha="0.35"/>
        </LinearLayout>

        <!-- Next / Skip buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/onboard_next"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="14dp"
            app:backgroundTint="@color/accent_cyan"
            android:textColor="@color/bg_dark"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkip"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="@string/onboard_skip"
            app:cornerRadius="14dp"
            style="@style/Widget.Material3.Button.TextButton"
            android:textColor="@color/text_muted"/>

    </LinearLayout>
</LinearLayout>
