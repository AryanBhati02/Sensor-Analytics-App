<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="80dp">

        <!-- Header -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="POWER" android:textColor="@color/accent_purple"
            android:textSize="11sp" android:letterSpacing="0.3" android:fontFamily="monospace"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tools" android:textColor="@color/text_primary"
            android:textSize="26sp" android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- WEBSOCKET / HTTP SERVER                                 -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🌐  PC LIVE DASHBOARD  (WiFi Server)"
            android:textColor="@color/text_muted" android:textSize="10sp"
            android:letterSpacing="0.15" android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="20dp"
            app:strokeColor="@color/divider" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <!-- What is this? -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Starts a tiny web server on your phone. Open the URL below in any browser on the same WiFi — see live sensor readings from your PC!"
                    android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:layout_marginBottom="14dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tvServerStatus"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="● OFFLINE" android:textColor="@color/text_muted"
                            android:textSize="12sp" android:fontFamily="monospace"/>
                        <TextView android:id="@+id/tvServerUrl"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="@color/accent_cyan"
                            android:textSize="13sp" android:fontFamily="monospace"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnServerToggle"
                        android:layout_width="wrap_content" android:layout_height="44dp"
                        android:text="▶ Start"
                        app:cornerRadius="10dp" app:backgroundTint="@color/accent_cyan"
                        android:textColor="@color/bg_dark" android:textSize="13sp"/>
                </LinearLayout>
                <TextView android:id="@+id/tvServerInfo"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Tap Start, then open the URL in your PC browser (same WiFi only)."
                    android:textColor="@color/text_muted" android:textSize="11sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- SENSOR SIMULATOR                                        -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🤖  SENSOR SIMULATOR  (Emulator / Testing)"
            android:textColor="@color/text_muted" android:textSize="10sp"
            android:letterSpacing="0.15" android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="20dp"
            app:strokeColor="@color/divider" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Generates fake sensor data to test the app on a PC emulator (no real sensors needed). Watch the Raw Console below for live output."
                    android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>
                <Spinner android:id="@+id/spinnerSimMode"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/spinner_bg" android:paddingStart="12dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvSimStatus"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Not running" android:textColor="@color/text_muted"
                        android:textSize="12sp" android:fontFamily="monospace"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSimToggle"
                        android:layout_width="wrap_content" android:layout_height="44dp"
                        android:text="▶ Start Simulation"
                        app:cornerRadius="10dp" app:backgroundTint="@color/accent_green"
                        android:textColor="@color/bg_dark" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- SENSOR BENCHMARK                                        -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚡  SENSOR BENCHMARK  (~12 seconds)"
            android:textColor="@color/text_muted" android:textSize="10sp"
            android:letterSpacing="0.15" android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="20dp"
            app:strokeColor="@color/divider" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBenchmark"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:text="⚡ Run Benchmark"
                    app:cornerRadius="12dp" app:backgroundTint="@color/accent_amber"
                    android:textColor="@color/bg_dark" android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>
                <TextView android:id="@+id/tvBenchResults"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Tap to measure how fast your sensors sample data."
                    android:textColor="@color/text_muted" android:textSize="12sp"
                    android:fontFamily="monospace" android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- TRIGGER ACTIONS                                         -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚡  TRIGGER ACTIONS  (Shake + Proximity)"
            android:textColor="@color/text_muted" android:textSize="10sp"
            android:letterSpacing="0.15" android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="20dp"
            app:strokeColor="@color/divider" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <!-- Shake → Flashlight -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔦  Shake to toggle flashlight"
                            android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Shake phone to turn torch ON/OFF"
                            android:textColor="@color/text_muted" android:textSize="11sp"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchFlashlight"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:checked="true"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"/>
                <!-- Proximity → Silence -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔇  Cover sensor to silence audio"
                            android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Hold hand near proximity sensor"
                            android:textColor="@color/text_muted" android:textSize="11sp"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSilence"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:checked="true"/>
                </LinearLayout>
                <TextView android:id="@+id/tvTriggerStatus"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Waiting for trigger…"
                    android:textColor="@color/accent_cyan" android:textSize="12sp"
                    android:fontFamily="monospace" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- GESTURE RECOGNIZER                                      -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🤌  GESTURE RECOGNIZER  (ML-based)"
            android:textColor="@color/text_muted" android:textSize="10sp"
            android:letterSpacing="0.15" android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="20dp"
            app:strokeColor="@color/divider" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <!-- Instructions -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="HOW TO USE:"
                    android:textColor="@color/accent_cyan" android:textSize="10sp"
                    android:fontFamily="monospace" android:letterSpacing="0.2"
                    android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="1. Tap RECORD and give the gesture a name (e.g. 'Shake')\n2. Perform the gesture for 2 seconds\n3. Repeat for different gestures\n4. Tap RECOGNISE — perform a gesture and see it detected"
                    android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:lineSpacingExtra="3dp" android:layout_marginBottom="14dp"/>

                <!-- Action buttons -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRecordGesture"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1.2" android:layout_marginEnd="6dp"
                        android:text="⏺ Record" android:textSize="11sp"
                        android:padding="0dp"
                        app:cornerRadius="10dp" app:backgroundTint="@color/accent_red"
                        android:textColor="@color/text_primary"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToggleRecognize"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="1.2" android:layout_marginEnd="6dp"
                        android:text="🎯 Recognise" android:textSize="11sp"
                        android:padding="0dp"
                        app:cornerRadius="10dp" app:backgroundTint="@color/accent_purple"
                        android:textColor="@color/text_primary"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGestureClear"
                        android:layout_width="0dp" android:layout_height="52dp"
                        android:layout_weight="0.6"
                        android:text="🗑" android:textSize="16sp"
                        android:padding="0dp"
                        app:cornerRadius="10dp" app:backgroundTint="@color/card_bg_elevated"
                        android:textColor="@color/text_muted"
                        app:strokeColor="@color/divider" app:strokeWidth="1dp"/>
                </LinearLayout>

                <!-- Status -->
                <TextView android:id="@+id/tvGestureStatus"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Ready — tap Record to train a gesture"
                    android:textColor="@color/accent_cyan" android:textSize="13sp"
                    android:fontFamily="monospace" android:layout_marginBottom="10dp"/>

                <!-- Template list -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvGestureTemplates"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Templates (3):\n  • Shake (built-in)\n  • Tilt Left (built-in)\n  • Flip (built-in)"
                    android:textColor="@color/text_muted" android:textSize="11sp"
                    android:fontFamily="monospace" android:lineSpacingExtra="3dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- RAW DATA CONSOLE                                        -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="💻  RAW DATA CONSOLE  (Live log)"
            android:textColor="@color/text_muted" android:textSize="10sp"
            android:letterSpacing="0.15" android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#0D131F" app:cardCornerRadius="16dp"
            app:strokeColor="@color/divider" app:strokeWidth="1dp">
            <ScrollView android:id="@+id/scrollConsole"
                android:layout_width="match_parent" android:layout_height="160dp"
                android:padding="12dp" android:fillViewport="true">
                <TextView android:id="@+id/tvConsole"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="[Ready — console logs will appear here]\n"
                    android:textColor="@color/accent_green" android:textSize="10sp"
                    android:fontFamily="monospace" android:lineSpacingExtra="2dp"/>
            </ScrollView>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- SCHEDULED RECORDING                                     -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⏰  SCHEDULED RECORDING  (WorkManager)"
            android:textColor="@color/text_muted" android:textSize="10sp"
            android:letterSpacing="0.15" android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="20dp"
            app:strokeColor="@color/divider" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSchedule"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:text="⏰ Schedule Auto-Recording"
                    app:cornerRadius="12dp" app:backgroundTint="@color/accent_cyan"
                    android:textColor="@color/bg_dark" android:textSize="14sp"
                    android:layout_marginBottom="10dp"/>
                <TextView android:id="@+id/tvScheduleStatus"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Not scheduled — recordings saved to Logger tab"
                    android:textColor="@color/text_muted" android:textSize="12sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- BLUETOOTH EXPORT                                        -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📶  BLUETOOTH EXPORT  (Send CSV to device)"
            android:textColor="@color/text_muted" android:textSize="10sp"
            android:letterSpacing="0.15" android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="20dp"
            app:strokeColor="@color/divider" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBluetooth"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:text="📶 Send Data to Paired Device"
                    app:cornerRadius="12dp" app:backgroundTint="@color/accent_blue"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:layout_marginBottom="10dp"/>
                <TextView android:id="@+id/tvBluetoothStatus"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Requires a paired BT device + data in Logger"
                    android:textColor="@color/text_muted" android:textSize="12sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- PDF REPORT                                              -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📄  PDF REPORT  (Export latest session)"
            android:textColor="@color/text_muted" android:textSize="10sp"
            android:letterSpacing="0.15" android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="20dp"
            app:strokeColor="@color/divider" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPdf"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:text="📄 Export Session as PDF"
                    app:cornerRadius="12dp" app:backgroundTint="@color/accent_red"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:layout_marginBottom="10dp"/>
                <TextView android:id="@+id/tvPdfStatus"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Exports latest Logger session as a formatted PDF"
                    android:textColor="@color/text_muted" android:textSize="12sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
