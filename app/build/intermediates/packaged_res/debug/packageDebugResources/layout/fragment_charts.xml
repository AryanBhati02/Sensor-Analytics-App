<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:fitsSystemWindows="true"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="20dp" android:paddingBottom="0dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="VISUALISE" android:textColor="@color/accent_cyan"
            android:textSize="11sp" android:letterSpacing="0.3" android:fontFamily="monospace"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Charts" android:textColor="@color/text_primary"
            android:textSize="26sp" android:textStyle="bold"/>
    </LinearLayout>

    <!-- 6-tab bar -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/chartTabLayout"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" android:background="@color/card_bg"
        app:tabGravity="fill" app:tabMode="scrollable"
        app:tabTextColor="@color/tab_text_cyan"
        app:tabIndicatorColor="@color/accent_cyan" app:tabIndicatorHeight="3dp"
        app:tabTextAppearance="@style/TabTextSmall">
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Waveform"/>
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Line"/>
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Light"/>
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Heatmap"/>
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Radar"/>
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="FFT"/>
    </com.google.android.material.tabs.TabLayout>

    <!-- Chart panels container -->
    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_margin="16dp">

        <!-- Panel 0: Waveform with aligned X/Y/Z legend -->
        <FrameLayout android:id="@+id/panelWaveform"
            android:layout_width="match_parent" android:layout_height="match_parent">
            <com.mad.sensorapp.views.WaveformView android:id="@+id/waveformView"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/chart_bg"/>
            <!-- X Y Z legend - top right aligned -->
            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="top|end"
                android:paddingEnd="10dp" android:paddingTop="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="■ X" android:textColor="#00E5FF" android:textSize="11sp"
                    android:fontFamily="monospace" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="■ Y" android:textColor="#00E676" android:textSize="11sp"
                    android:fontFamily="monospace" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="■ Z" android:textColor="#FFB300" android:textSize="11sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Panel 1: Line Chart -->
        <FrameLayout android:id="@+id/panelLine"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:visibility="gone">
            <com.github.mikephil.charting.charts.LineChart android:id="@+id/lineChart"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/chart_bg"/>
        </FrameLayout>

        <!-- Panel 2: Light Chart + Gauge -->
        <FrameLayout android:id="@+id/panelLight"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:background="@drawable/chart_bg">
                <TextView android:id="@+id/tvLightLux"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:layout_marginTop="16dp"
                    android:text="0 lx" android:textColor="@color/accent_cyan"
                    android:textSize="22sp" android:textStyle="bold" android:fontFamily="monospace"/>
                <!-- Animated arc gauge for light level -->
                <com.mad.sensorapp.views.GaugeView
                    android:id="@+id/lightGauge"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
                <!-- Line chart below -->
                <com.github.mikephil.charting.charts.LineChart android:id="@+id/lightChart"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Panel 3: Heatmap -->
        <FrameLayout android:id="@+id/panelHeatmap"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:background="@drawable/chart_bg"
                android:padding="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ACCEL HEATMAP  ·  X / Y / Z intensity over time"
                    android:textColor="@color/text_muted" android:textSize="10sp"
                    android:fontFamily="monospace" android:layout_marginBottom="8dp"/>
                <com.mad.sensorapp.views.HeatmapView android:id="@+id/heatmapView"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Panel 4: Radar -->
        <FrameLayout android:id="@+id/panelRadar"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:visibility="gone">
            <com.github.mikephil.charting.charts.RadarChart android:id="@+id/radarChart"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/chart_bg"/>
        </FrameLayout>

        <!-- Panel 5: FFT -->
        <FrameLayout android:id="@+id/panelFft"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:visibility="gone">
            <com.github.mikephil.charting.charts.BarChart android:id="@+id/fftChart"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/chart_bg"/>
        </FrameLayout>
    </FrameLayout>

    <!-- FFT info bar -->
    <TextView android:id="@+id/tvFftInfo"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="8dp"
        android:text="Dominant: — Hz" android:textColor="@color/accent_cyan"
        android:textSize="11sp" android:fontFamily="monospace" android:gravity="center"
        android:visibility="gone"/>

</LinearLayout>
