<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:fitsSystemWindows="true"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PREFERENCES" android:textColor="@color/accent_amber"
            android:textSize="11sp" android:letterSpacing="0.3" android:fontFamily="monospace"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Settings" android:textColor="@color/text_primary"
            android:textSize="28sp" android:textStyle="bold"
            android:layout_marginBottom="28dp"/>

        <!-- ── Appearance ──────────────────────────────────────────────── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="APPEARANCE" android:textColor="@color/text_muted"
            android:textSize="10sp" android:letterSpacing="0.2" android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="16dp"
            app:strokeColor="@color/divider" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="4dp">

                <!-- Dark mode -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/settings_dark_mode"
                        android:textColor="@color/text_primary" android:textSize="15sp"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:checked="true"
                        app:trackTint="@color/switch_track_tint"
                        app:thumbTint="@color/switch_thumb_tint"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Sensor ─────────────────────────────────────────────────── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SENSORS" android:textColor="@color/text_muted"
            android:textSize="10sp" android:letterSpacing="0.2" android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="16dp"
            app:strokeColor="@color/divider" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="4dp">

                <!-- Sampling rate -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/settings_sampling"
                            android:textColor="@color/text_primary" android:textSize="15sp"/>
                        <TextView android:id="@+id/tvSamplingLabel"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="5 Hz" android:textColor="@color/accent_cyan"
                            android:textSize="14sp" android:fontFamily="monospace"/>
                    </LinearLayout>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderSamplingRate"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:valueFrom="1" android:valueTo="50"
                        android:value="5" android:stepSize="1"
                        app:trackColor="@color/divider"
                        app:thumbColor="@color/accent_cyan"
                        app:trackColorActive="@color/accent_cyan"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider"/>

                <!-- Background service -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/settings_bg_service"
                            android:textColor="@color/text_primary" android:textSize="15sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Monitor sensors in background"
                            android:textColor="@color/text_muted" android:textSize="11sp"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchBackgroundService"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        app:trackTint="@color/switch_track_tint"
                        app:thumbTint="@color/switch_thumb_tint"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Display ────────────────────────────────────────────────── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DISPLAY" android:textColor="@color/text_muted"
            android:textSize="10sp" android:letterSpacing="0.2" android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="16dp"
            app:strokeColor="@color/divider" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="4dp">

                <!-- Floating HUD -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/settings_floating_hud"
                            android:textColor="@color/text_primary" android:textSize="15sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Shows live values over other apps"
                            android:textColor="@color/text_muted" android:textSize="11sp"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchFloatingHud"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        app:trackTint="@color/switch_track_tint"
                        app:thumbTint="@color/switch_thumb_tint"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider"/>

                <!-- Always on -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/settings_always_on"
                            android:textColor="@color/text_primary" android:textSize="15sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Keeps screen on while in app"
                            android:textColor="@color/text_muted" android:textSize="11sp"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAlwaysOn"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        app:trackTint="@color/switch_track_tint"
                        app:thumbTint="@color/switch_thumb_tint"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Data ───────────────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearData"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="20dp"
            android:text="@string/settings_clear_data"
            app:cornerRadius="14dp"
            app:backgroundTint="#1AFF3B3B"
            android:textColor="@color/accent_red"
            app:strokeColor="@color/accent_red"
            app:strokeWidth="1dp"/>

        <!-- Version -->
        <TextView android:id="@+id/tvVersion"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="v2.0 — SensorPro"
            android:textColor="@color/text_muted" android:textSize="12sp"
            android:fontFamily="monospace" android:gravity="center"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
