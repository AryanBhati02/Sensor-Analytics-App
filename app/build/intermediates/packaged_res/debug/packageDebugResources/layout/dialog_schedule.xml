<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="24dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Duration (seconds):" android:textColor="#EAEEF5" android:textSize="14sp"
        android:layout_marginBottom="8dp"/>
    <EditText android:id="@+id/etScheduleDuration"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:hint="60" android:inputType="number"
        android:background="@drawable/stats_row_bg"
        android:textColor="#EAEEF5" android:textColorHint="#4A5568"
        android:padding="12dp"/>
</LinearLayout>
